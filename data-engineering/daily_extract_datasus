import requests
import pandas as pd
import os
import boto3
from datetime import datetime

# --- CREDENCIAIS AWS ---
AWS_ACCESS_KEY = "COLE_SUA_ACCESS_KEY_AQUI"
AWS_SECRET_KEY = "COLE_SUA_SECRET_KEY_AQUI"
BUCKET_NAME = "smia-datalake-lpissaia"

def upload_to_s3(local_file: str, bucket_name: str, s3_file_name: str):
    s3 = boto3.client(
        's3',
        aws_access_key_id=AWS_ACCESS_KEY,
        aws_secret_access_key=AWS_SECRET_KEY
    )
    print(f" -> Subindo para o S3: s3://{bucket_name}/{s3_file_name}")
    try:
        s3.upload_file(local_file, bucket_name, s3_file_name)
        print("   ✅ Upload concluído!")
    except Exception as e:
        print(f"   ❌ Erro no upload: {e}")

def fetch_daily_sinan_api(doenca: str, ano: int, limite_paginas: int = 5) -> pd.DataFrame:
    print(f"Buscando atualizações recentes de {doenca.upper()} via API REST...")
    todos_os_registros = []
    
    for page in range(1, limite_paginas + 1):
        url = f"https://apidadosabertos.saude.gov.br/arboviroses/{doenca}?nu_ano={ano}&limit=20&offset={page}"
        try:
            resp = requests.get(url, timeout=15)
            if resp.status_code == 200:
                data = resp.json()
                registros = data.get("parametros", [])
                
                if not registros:
                    break
                    
                todos_os_registros.extend(registros)
            else:
                break
        except Exception as e:
            print(f" -> Erro de conexão: {e}")
            break

    if todos_os_registros:
        dados_convertidos = [
            {k: v for k, v in item.items() if isinstance(v, (int, float, str, bool))}
            for item in todos_os_registros if isinstance(item, dict)
        ]
        return pd.DataFrame(dados_convertidos)
    
    return pd.DataFrame()

def main():
    ano_atual = datetime.now().year
    data_hoje = datetime.now().strftime("%Y-%m-%d")
    
    print("Iniciando Carga Incremental Diária (DataSUS API)")
    print("-" * 60)
    
    # Busca as últimas 10 páginas (200 registros mais recentes inseridos no sistema nacional)
    df_incremental = fetch_daily_sinan_api("dengue", ano_atual, limite_paginas=10)
    
    if not df_incremental.empty:
        # Filtra para manter apenas São Paulo (Código IBGE 35) no DataFrame, mantendo o padrão do backfill
        if 'sg_uf_not' in df_incremental.columns:
            df_incremental = df_incremental[df_incremental['sg_uf_not'] == '35']
            
        if not df_incremental.empty:
            output_dir = "raw"
            os.makedirs(output_dir, exist_ok=True)
            
            file_name = f"sinan_incremental_dengue_SP_{data_hoje}.parquet"
            file_path = os.path.join(output_dir, file_name)
            
            df_incremental = df_incremental.astype(str)
            df_incremental.to_parquet(file_path, index=False)
            
            print(f" -> 💾 Salvo em Parquet: {len(df_incremental)} novos registros para SP.")
            
            s3_key = f"datasus_incremental/{file_name}"
            upload_to_s3(file_path, BUCKET_NAME, s3_key)
        else:
            print(" -> Sem registros novos para SP nas últimas atualizações do sistema.")
    else:
        print("Nenhum dado novo encontrado na API hoje.")

if __name__ == "__main__":
    main()